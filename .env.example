# .env.example — committed contract for the env vars Bearings reads.
#
# Copy this to `.env` (which is .gitignore'd) for local dev, then edit
# values as needed. Settings (src/bearings/config.py) reads from
# `.env` first, then process env (which overrides). All variables
# below are optional — the defaults in `config.py` apply if unset.
#
# Variable names follow the `BEARINGS_<FIELD>` pattern set by
# `env_prefix="BEARINGS_"` in SettingsConfigDict. Field names match
# the Pydantic model attributes (case-insensitive).

# Human-readable application name. Stamped into log events.
BEARINGS_APP_NAME=bearings

# Deployment environment. One of: development, staging, production.
# Drives log format (dev → coloured console; prod → JSON) and error
# verbosity.
BEARINGS_ENVIRONMENT=development

# Minimum log level. One of: DEBUG, INFO, WARNING, ERROR, CRITICAL.
BEARINGS_LOG_LEVEL=INFO

# If true, emit logs as one-JSON-object-per-line (machine-parseable).
# Off in dev (use ConsoleRenderer for colour); on in prod
# (aggregator-friendly).
BEARINGS_LOG_JSON=false

# Writeable directory for runtime state (SQLite DB, future caches).
# Defaults to $XDG_DATA_HOME/bearings or ~/.local/share/bearings.
# Override in tests / CI / containers as needed.
# BEARINGS_DATA_DIR=/var/lib/bearings

# SQLite database filename inside data_dir.
# BEARINGS_DB_FILENAME=bearings.sqlite3
