# Python — repo-root build artifacts only. Anchored with leading
# slash so the SvelteKit static-adapter output at
# `src/bearings/web/dist/` (item 2.1) is NOT ignored — that bundle
# ships inside the wheel via `[tool.hatch.build.targets.wheel]
# packages = ["src/bearings"]` and is committed so a fresh clone
# serves the UI without a Node toolchain.
__pycache__/
*.py[cod]
*$py.class
*.egg-info/
.eggs/
/build/
/dist/
*.so

# uv / virtualenv
.venv/
venv/
.python-version

# Tooling caches
.mypy_cache/
.ruff_cache/
.pytest_cache/
.coverage
.coverage.*
htmlcov/
coverage.xml

# Pre-commit caches (the .githooks-v1/pre-commit shim itself IS tracked).
.pre-commit-cache/
.githooks-v1/*.sample
.githooks-v1/*.legacy

# IDE / editor
.vscode/
.idea/
*.swp

# Frontend — install/cache artifacts. The static-adapter build output
# lives at `src/bearings/web/dist/` (committed) per item 2.1.
frontend/node_modules/
frontend/.svelte-kit/
frontend/build/
frontend/dist/
frontend/coverage/

# Playwright — runtime artefacts (item 3.1). The `e2e/` source tree is
# tracked; only the run-output directories are ignored.
frontend/playwright-report/
frontend/test-results/
frontend/blob-report/
frontend/playwright/.cache/

# Local data + secrets
.env
.env.local
*.db
*.db-journal
*.db-wal
*.db-shm

# OS
.DS_Store
Thumbs.db
.playwright-mcp/
output/playwright/

# Autonomous frontend-parity audit loop — orchestrator state, gap
# JSONL, and per-cycle audit prose. Loop driver lives in
# ~/.claude/plans/melodic-toasting-axolotl.md.
.audit-loop/
