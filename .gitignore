# Python
__pycache__/
*.py[cod]
*$py.class
.venv/
venv/
dist/
build/
*.egg-info/
.mypy_cache/
.ruff_cache/
.pytest_cache/
.tox/
.coverage
htmlcov/

# Project
*.db
*.db-journal
*.db-wal
*.db-shm
.env
*.bak
.claude/sessions/

# Frontend artifacts (see also frontend/.gitignore)
node_modules/
frontend/build/
frontend/.svelte-kit/

# Generated static bundle — tracked placeholder only
src/bearings/web/dist/*
!src/bearings/web/dist/.gitkeep

# Playwright MCP snapshots (transient)
.playwright-mcp/

# Ad-hoc debug screenshots that accumulate in the repo root during
# UI investigations (DnD probe, activity-row tuning, bearings-top
# layout). Root-level `*.png` only — intentional graphics (icons,
# favicons) live under specific subdirs and stay tracked.
/*.png

# Bearings Directory Context — per-session ephemera. Identity files
# (manifest.toml, pending.toml, state.toml) stay tracked; the log
# files churn on every session start and don't carry portable state.
.bearings/history.jsonl
.bearings/last_on_open.json
.bearings/corrupted-*

# Editors / OS
.idea/
.vscode/
*.swp
.DS_Store
